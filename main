<body>

    <h1>Power Clash</h1>
    <p>Choisis le guerrier le plus puissant !</p>

    <div class="container">
        <div class="card" id="char1" onclick="vote(0)">
            <img src="" alt="" id="img1">
            <div class="name" id="name1"></div>
        </div>

        <div class="vs">VS</div>

        <div class="card" id="char2" onclick="vote(1)">
            <img src="" alt="" id="img2">
            <div class="name" id="name2"></div>
        </div>
    </div>

    <button id="next-btn" onclick="loadDuel()">DUEL SUIVANT ⚔️</button>

    <script>
        const characters = [
            { name: "Goku", img: "https://api.culturel.com/images/perso/goku.jpg" },
            { name: "Saitama", img: "https://m.media-amazon.com/images/I/51fH0-p-HhL.jpg" },
            { name: "Luffy", img: "https://m.media-amazon.com/images/I/719fH236W1L.jpg" },
            { name: "Naruto", img: "https://m.media-amazon.com/images/I/81p-W5Zl5eL._AC_SL1500_.jpg" },
            { name: "Gojo Satoru", img: "https://m.media-amazon.com/images/I/718t-Mv6UuL.jpg" },
            { name: "Vegeta", img: "https://m.media-amazon.com/images/I/61b7L4FAn9L._AC_SL1200_.jpg" },
            { name: "Sukuna", img: "https://m.media-amazon.com/images/I/71I9UuEun3L._AC_SL1200_.jpg" },
            { name: "Eren Yeager", img: "https://m.media-amazon.com/images/I/81S65-YQk6L._AC_SL1500_.jpg" }
        ];

        function loadDuel() {
            document.getElementById('next-btn').style.display = 'none';
            
            let i1 = Math.floor(Math.random() * characters.length);
            let i2 = Math.floor(Math.random() * characters.length);

            while (i1 === i2) {
                i2 = Math.floor(Math.random() * characters.length);
            }

            document.getElementById('name1').innerText = characters[i1].name;
            document.getElementById('img1').src = characters[i1].img;
            document.getElementById('name2').innerText = characters[i2].name;
            document.getElementById('img2').src = characters[i2].img;

            document.querySelectorAll('.card').forEach(c => {
                c.style.opacity = "1";
                c.style.pointerEvents = "auto";
                c.style.borderColor = "transparent";
            });
        }

        function vote(winnerIndex) {
            const cards = [document.getElementById('char1'), document.getElementById('char2')];
            cards[winnerIndex].style.borderColor = "#2ecc71";
            cards[1 - winnerIndex].style.opacity = "0.3";
            cards.forEach(c => c.style.pointerEvents = "none");
            document.getElementById('next-btn').style.display = 'block';
        }

        window.onload = loadDuel;
    </script>
</body>
