<body>

    <h1>Power Clash</h1>
    <p>Clique sur le personnage le plus puissant selon toi !</p>

    <div class="container">
        <!-- Perso 1 -->
        <div class="card" id="char1" onclick="vote(0)">
            <img src="" alt="Perso 1" id="img1">
            <div class="name" id="name1">Chargement...</div>
        </div>

        <div class="vs">VS</div>

        <!-- Perso 2 -->
        <div class="card" id="char2" onclick="vote(1)">
            <img src="" alt="Perso 2" id="img2">
            <div class="name" id="name2">Chargement...</div>
        </div>
    </div>

    <button id="next-btn" onclick="loadDuel()">Duel Suivant ⚔️</button>

    <script>
        // Ta liste de personnages (ajoute les liens d'images ici)
        const characters = [
            { name: "Goku", img: "https://sm.ign.com/ign_fr/cover/g/goku/goku_6n9e.jpg" },
            { name: "Saitama", img: "https://img.截取.com/onepunchman.jpg" }, // Remplace par des vrais liens
            { name: "Luffy", img: "https://m.media-amazon.com/images/I/719fH236W1L.jpg" },
            { name: "Naruto", img: "https://static.wikia.nocookie.net/naruto/images/d/d6/Naruto_Part_I.png" },
            { name: "Gojo Satoru", img: "https://m.media-amazon.com/images/I/718t-Mv6UuL.jpg" },
            { name: "Madara Uchiha", img: "https://static.wikia.nocookie.net/naruto/images/4/43/Madara_Uchiha.png" }
        ];

        function loadDuel() {
            // Cacher le bouton "Suivant"
            document.getElementById('next-btn').style.display = 'none';
            
            // Choisir deux persos au hasard
            let index1 = Math.floor(Math.random() * characters.length);
            let index2 = Math.floor(Math.random() * characters.length);

            // Eviter d'avoir le même perso
            while (index1 === index2) {
                index2 = Math.floor(Math.random() * characters.length);
            }

            // Mettre à jour l'affichage
            document.getElementById('name1').innerText = characters[index1].name;
            document.getElementById('img1').src = characters[index1].img;
            
            document.getElementById('name2').innerText = characters[index2].name;
            document.getElementById('img2').src = characters[index2].img;

            // Reset l'opacité
            document.getElementById('char1').style.opacity = "1";
            document.getElementById('char2').style.opacity = "1";
        }

        function vote(winnerIndex) {
            // Petite animation visuelle
            const c1 = document.getElementById('char1');
            const c2 = document.getElementById('char2');
            
            if(winnerIndex === 0) {
                c2.style.opacity = "0.3";
                alert("Victoire pour " + document.getElementById('name1').innerText + " !");
            } else {
                c1.style.opacity = "0.3";
                alert("Victoire pour " + document.getElementById('name2').innerText + " !");
            }

            document.getElementById('next-btn').style.display = 'block';
        }

        // Lancer le premier duel
        loadDuel();
    </script>
